# Database
DB_USER=appuser
DB_PASSWORD=apppass
DB_NAME=appdb
DB_HOST=db
DB_PORT=5432

# JWT
JWT_SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ALLOW_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Storage
STORAGE_PROVIDER=local
BOOK_STORAGE_DIR=storage/books
# S3 settings are used only when STORAGE_PROVIDER=s3
S3_BUCKET_NAME=
S3_REGION=us-east-1
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# LLM
LLM_ENABLED=true
# Active provider flag: use "ollama", "grok", "gpt", or "chatgpt"
LLM_PROVIDER=ollama
# Set this to the model name for the active provider:
# - Ollama example: llama3
# - Grok example: use your Grok model id
# - ChatGPT example: gpt-4o-mini
LLM_MODEL=phi3:mini
# Local LLM base URL (used when LLM_PROVIDER=ollama)
LLM_BASE_URL=http://ollama:11434
LLM_TIMEOUT_SECONDS=300
# Grok settings are used only when LLM_PROVIDER=grok
GROK_BASE_URL=https://api.x.ai/v1
GROK_API_KEY=

# ChatGPT settings are used only when LLM_PROVIDER=gpt or LLM_PROVIDER=chatgpt
GPT_API_KEY=
GPT_BASE_URL=https://api.openai.com/v1
